{
  "name": "boaredev",
  "version": "0.1.0",
  "description": "Protocol + skills for AI-assisted development. Install once, works with Claude, Cursor, Copilot, Gemini.",
  "keywords": ["ai", "claude", "cursor", "copilot", "gemini", "developer-protocol", "skills"],
  "license": "MIT",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "pack:check": "npm pack --json",
    "publish:dry-run": "npm publish --dry-run"
  },
  "bin": {
    "boaredev": "./bin/cli.js"
  },
  "main": "./installer/index.js",
  "files": [
    "bin/",
    "installer/",
    "skills/",
    "tools/",
    "project-template/",
    "protocol/",
    "padroes/"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauloboare/boaredev.git"
  },
  "homepage": "https://github.com/pauloboare/boaredev#readme",
  "bugs": {
    "url": "https://github.com/pauloboare/boaredev/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
